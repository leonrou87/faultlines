# Fault Lines (cloud reader app) — environment. Copy to .env.local for local dev.
# All NEXT_PUBLIC_* values are exposed to the browser (not secret).

# --- Supabase (reads published stories; powers voting) ---
NEXT_PUBLIC_SUPABASE_URL=https://euqyxgsoyzqjqeajxdvr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key from Supabase>

# --- Google AdSense (optional; ads show as placeholders until set) ---
# 1. Sign up at https://adsense.google.com, add site faultlines.kytepush.com
# 2. Once you have your publisher ID, set this and redeploy (this also serves /ads.txt
#    and injects the AdSense script for site verification):
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# 3. After approval, create an in-feed ad unit and set its slot id:
# NEXT_PUBLIC_ADSENSE_SLOT_INFEED=XXXXXXXXXX
